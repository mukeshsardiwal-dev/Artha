# ─── macOS ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ─── Editor / IDE ─────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# ─── Claude Code ──────────────────────────────────────────
.claude/

# ─── Backend (Python / FastAPI) ───────────────────────────
backend/.env
backend/.env.*
!backend/.env.example

backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# Uploaded user files — use cloud storage in production
backend/uploads/

# Python build artifacts
backend/*.egg-info/
backend/dist/
backend/build/
backend/.eggs/

# Test / coverage
backend/.coverage
backend/htmlcov/
backend/.pytest_cache/

# ─── Frontend (Node / Vite / React) ───────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.production
frontend/.env.*
!frontend/.env.example

# Vite cache
frontend/.vite/

# TypeScript build info
frontend/tsconfig.tsbuildinfo

# ─── Secrets — never commit these ─────────────────────────
*.pem
*.key
*.p12
*.pfx
.env
.env.local
.env.production
.env.staging

# ─── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Project-specific ─────────────────────────────────────
# Extracted pitch deck — not needed in repo
pptx_extracted/

# Large binary files
*.pptx
*.zip
*.tar.gz
