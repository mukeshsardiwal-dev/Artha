DATABASE_URL=postgres://postgres:password@localhost:5432/mandibook
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Comma-separated list of allowed frontend origins (no trailing slash).
# Add your deployed frontend URL here, e.g. https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── OpenTelemetry (optional) ───────────────────────────────────────────────
# Service name shown in your tracing backend
OTEL_SERVICE_NAME=artha-api

# OTLP HTTP endpoint — remove or leave blank to disable remote tracing.
# Grafana Cloud : https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# Honeycomb     : https://api.honeycomb.io
# SigNoz Cloud  : https://ingest.us.signoz.cloud:443
OTEL_EXPORTER_OTLP_ENDPOINT=

# Auth header(s) for the above endpoint — comma-separated Key=Value pairs.
# Grafana Cloud : Authorization=Basic <base64-encoded-instanceid:apikey>
# Honeycomb     : x-honeycomb-team=<your-api-key>
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_CONSOLE=false
